{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    "languages/typescript/packages/*": {
      "ignoreDependencies": ["@parallax/.+"]
    },
    "languages/typescript/examples/*": {
      "entry": ["parallax.config.js", "src/main.ts"],
      "ignoreDependencies": ["@parallax/.+"],
      "ignoreUnresolved": ["#parallax"]
    }
  },
  "ignoreExportsUsedInFile": true,
  "ignore": [
    ".uv-cache/**",
    "**/test/fixtures/**",
    "languages/typescript/vitest.config.ts",
    "languages/typescript/scripts/render-guide.mjs",
    "languages/typescript/scripts/generate-case-types.mjs",
    "languages/typescript/packages/conformance/src/case-format.generated.ts"
  ]
}
