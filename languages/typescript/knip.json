{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    "languages/typescript/packages/*": {
      "ignoreDependencies": ["@parallax/.+"]
    },
    "languages/typescript/examples/*": {
      "entry": ["parallax.config.js", "src/main.ts"],
      "ignoreDependencies": ["@parallax/.+"]
    }
  },
  "ignoreExportsUsedInFile": true,
  "ignore": ["**/test/fixtures/**", "languages/typescript/vitest.config.ts"]
}
