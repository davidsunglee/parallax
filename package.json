{
  "name": "parallax",
  "version": "0.0.0",
  "private": true,
  "license": "Apache-2.0",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22.13"
  },
  "description": "Dev-tooling only (husky, commitlint, markdownlint, lint-staged) for the parallax polyglot monorepo. No runtime code lives here.",
  "scripts": {
    "prepare": "husky",
    "markdownlint": "markdownlint-cli2 \"core/spec/**/*.md\" \"*.md\"",
    "commitlint": "commitlint",
    "ts:typecheck": "tsc -b languages/typescript/tsconfig.json",
    "ts:typecheck-tests": "pnpm run ts:typecheck && node languages/typescript/scripts/typecheck-tests.mjs",
    "ts:test": "vitest run --root languages/typescript",
    "ts:coverage": "vitest run --root languages/typescript --coverage",
    "ts:conformance-coverage": "pnpm run ts:typecheck && node languages/typescript/scripts/conformance-slice-coverage.mjs --json coverage/conformance-slice.json --markdown coverage/conformance-slice.md",
    "ts:generate-case-types": "node languages/typescript/scripts/generate-case-types.mjs",
    "ts:generate-case-types:check": "pnpm run ts:generate-case-types && git diff --exit-code -- languages/typescript/packages/conformance/src/case-format.generated.ts",
    "ts:lint": "pnpm run ts:generate-case-types:check && pnpm run ts:biome && pnpm run ts:dep-graph",
    "ts:biome": "biome check languages/typescript",
    "ts:dep-graph": "depcruise --config languages/typescript/.dependency-cruiser.cjs languages/typescript/packages/*/src",
    "ts:package-check": "pnpm run ts:publint && pnpm run ts:attw && pnpm run ts:knip",
    "ts:publint": "pnpm -r --filter \"@parallax/*\" exec publint --strict",
    "ts:attw": "pnpm -r --filter \"@parallax/*\" exec attw --pack --profile esm-only .",
    "ts:knip": "knip --config languages/typescript/knip.json"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.5",
    "@biomejs/biome": "^2.5.3",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "dependency-cruiser": "^18.1.0",
    "husky": "^9.1.7",
    "json-schema-to-typescript": "^15.0.4",
    "knip": "^6.26.0",
    "lint-staged": "^17.0.8",
    "markdownlint-cli2": "^0.23.0",
    "publint": "^0.3.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "lint-staged": {
    "*.md": "markdownlint-cli2"
  }
}
