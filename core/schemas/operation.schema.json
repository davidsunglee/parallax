{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://parallax.dev/schemas/operation.schema.json",
  "title": "Parallax Operation Algebra (M2)",
  "description": "Canonical, format-agnostic serialization of an M2 operation node. Each node is a single-key tagged object. Grown one algebra phase at a time; this revision covers the full non-temporal single-entity algebra (identities, equality/range, null, string with case-insensitive + escape rules, membership, boolean incl. the first-class group node, orderBy / limit / distinct), the relationship algebra (navigate(rel) -> predicate, exists / notExists, the deepFetch directive), AND the aggregation algebra (groupBy with aggregate functions sum/avg/count/min/max/stdDev*/variance* and an optional having expression built from gt/gte/lt/lte/eq/notEq comparisons composed with and/or), AND the temporal algebra (asOf / asOfRange pin a temporal dimension and history returns the full milestone set; the from/to as-of predicates are auto-injected from the M7 as-of model, never written by the user), AND nested-attribute access into a valueObject (the `nestedEq` / `nestedNotEq` predicates compare an inner JSONB field referenced by a dotted path `Class.valueObject.field` against a literal, lowering to a JSONB extraction). A BITEMPORAL entity is pinned on both axes by NESTING two asOf nodes (one per asOfAttribute), so a read can fix business date and processing date independently (Phase 8).",
  "$ref": "#/$defs/operation",
  "$defs": {
    "attributeRef": {
      "description": "A metamodel attribute reference of the form Class.attribute.",
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9]*\\.[a-z][A-Za-z0-9]*$"
    },
    "relationshipRef": {
      "description": "A metamodel relationship reference of the form Class.relationship.",
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9]*\\.[a-z][A-Za-z0-9]*$"
    },
    "aggregateAlias": {
      "description": "An aggregate result-column name (the `as` of an aggregate function). Lowercase, snake_case allowed (e.g. total_quantity, sample_count), matching the canonical SQL alias.",
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "navigationPath": {
      "description": "An ordered list of relationship references naming one path to eager-fetch, e.g. ['Order.items'] (one hop) or ['Order.items', 'OrderItem.product'] (multi-hop).",
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/relationshipRef" }
    },
    "literal": {
      "description": "A scalar literal value usable as a bind.",
      "type": ["string", "number", "boolean", "null"]
    },
    "operation": {
      "type": "object",
      "minProperties": 1,
      "maxProperties": 1,
      "oneOf": [
        { "$ref": "#/$defs/all" },
        { "$ref": "#/$defs/none" },
        { "$ref": "#/$defs/eq" },
        { "$ref": "#/$defs/notEq" },
        { "$ref": "#/$defs/greaterThan" },
        { "$ref": "#/$defs/greaterThanEquals" },
        { "$ref": "#/$defs/lessThan" },
        { "$ref": "#/$defs/lessThanEquals" },
        { "$ref": "#/$defs/between" },
        { "$ref": "#/$defs/isNull" },
        { "$ref": "#/$defs/isNotNull" },
        { "$ref": "#/$defs/like" },
        { "$ref": "#/$defs/notLike" },
        { "$ref": "#/$defs/startsWith" },
        { "$ref": "#/$defs/endsWith" },
        { "$ref": "#/$defs/contains" },
        { "$ref": "#/$defs/in" },
        { "$ref": "#/$defs/notIn" },
        { "$ref": "#/$defs/and" },
        { "$ref": "#/$defs/or" },
        { "$ref": "#/$defs/not" },
        { "$ref": "#/$defs/group" },
        { "$ref": "#/$defs/orderBy" },
        { "$ref": "#/$defs/limit" },
        { "$ref": "#/$defs/distinct" },
        { "$ref": "#/$defs/navigate" },
        { "$ref": "#/$defs/exists" },
        { "$ref": "#/$defs/notExists" },
        { "$ref": "#/$defs/deepFetch" },
        { "$ref": "#/$defs/groupBy" },
        { "$ref": "#/$defs/asOf" },
        { "$ref": "#/$defs/asOfRange" },
        { "$ref": "#/$defs/history" },
        { "$ref": "#/$defs/nestedEq" },
        { "$ref": "#/$defs/nestedNotEq" }
      ]
    },

    "all": {
      "type": "object",
      "additionalProperties": false,
      "required": ["all"],
      "properties": {
        "all": { "type": "object", "additionalProperties": false }
      }
    },
    "none": {
      "type": "object",
      "additionalProperties": false,
      "required": ["none"],
      "properties": {
        "none": { "type": "object", "additionalProperties": false }
      }
    },

    "comparison": {
      "type": "object",
      "additionalProperties": false,
      "required": ["attr", "value"],
      "properties": {
        "attr": { "$ref": "#/$defs/attributeRef" },
        "value": { "$ref": "#/$defs/literal" }
      }
    },
    "eq": {
      "type": "object",
      "additionalProperties": false,
      "required": ["eq"],
      "properties": { "eq": { "$ref": "#/$defs/comparison" } }
    },
    "notEq": {
      "type": "object",
      "additionalProperties": false,
      "required": ["notEq"],
      "properties": { "notEq": { "$ref": "#/$defs/comparison" } }
    },
    "greaterThan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["greaterThan"],
      "properties": { "greaterThan": { "$ref": "#/$defs/comparison" } }
    },
    "greaterThanEquals": {
      "type": "object",
      "additionalProperties": false,
      "required": ["greaterThanEquals"],
      "properties": { "greaterThanEquals": { "$ref": "#/$defs/comparison" } }
    },
    "lessThan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lessThan"],
      "properties": { "lessThan": { "$ref": "#/$defs/comparison" } }
    },
    "lessThanEquals": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lessThanEquals"],
      "properties": { "lessThanEquals": { "$ref": "#/$defs/comparison" } }
    },

    "between": {
      "type": "object",
      "additionalProperties": false,
      "required": ["between"],
      "properties": {
        "between": {
          "type": "object",
          "additionalProperties": false,
          "required": ["attr", "lower", "upper"],
          "properties": {
            "attr": { "$ref": "#/$defs/attributeRef" },
            "lower": { "$ref": "#/$defs/literal" },
            "upper": { "$ref": "#/$defs/literal" }
          }
        }
      }
    },

    "nullCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": ["attr"],
      "properties": { "attr": { "$ref": "#/$defs/attributeRef" } }
    },
    "isNull": {
      "type": "object",
      "additionalProperties": false,
      "required": ["isNull"],
      "properties": { "isNull": { "$ref": "#/$defs/nullCheck" } }
    },
    "isNotNull": {
      "type": "object",
      "additionalProperties": false,
      "required": ["isNotNull"],
      "properties": { "isNotNull": { "$ref": "#/$defs/nullCheck" } }
    },

    "stringMatch": {
      "description": "A string predicate. `value` is a plain string; `like`/`notLike` interpret `%`/`_` as wildcards, the affix forms (startsWith/endsWith/contains) treat `value` as a literal and the implementation escapes wildcards. `caseInsensitive` defaults to false.",
      "type": "object",
      "additionalProperties": false,
      "required": ["attr", "value"],
      "properties": {
        "attr": { "$ref": "#/$defs/attributeRef" },
        "value": { "type": "string" },
        "caseInsensitive": { "type": "boolean", "default": false }
      }
    },
    "like": {
      "type": "object",
      "additionalProperties": false,
      "required": ["like"],
      "properties": { "like": { "$ref": "#/$defs/stringMatch" } }
    },
    "notLike": {
      "type": "object",
      "additionalProperties": false,
      "required": ["notLike"],
      "properties": { "notLike": { "$ref": "#/$defs/stringMatch" } }
    },
    "startsWith": {
      "type": "object",
      "additionalProperties": false,
      "required": ["startsWith"],
      "properties": { "startsWith": { "$ref": "#/$defs/stringMatch" } }
    },
    "endsWith": {
      "type": "object",
      "additionalProperties": false,
      "required": ["endsWith"],
      "properties": { "endsWith": { "$ref": "#/$defs/stringMatch" } }
    },
    "contains": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contains"],
      "properties": { "contains": { "$ref": "#/$defs/stringMatch" } }
    },

    "membership": {
      "type": "object",
      "additionalProperties": false,
      "required": ["attr", "values"],
      "properties": {
        "attr": { "$ref": "#/$defs/attributeRef" },
        "values": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/literal" }
        }
      }
    },
    "in": {
      "type": "object",
      "additionalProperties": false,
      "required": ["in"],
      "properties": { "in": { "$ref": "#/$defs/membership" } }
    },
    "notIn": {
      "type": "object",
      "additionalProperties": false,
      "required": ["notIn"],
      "properties": { "notIn": { "$ref": "#/$defs/membership" } }
    },

    "junction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operands"],
      "properties": {
        "operands": {
          "type": "array",
          "minItems": 2,
          "items": { "$ref": "#/$defs/operation" }
        }
      }
    },
    "and": {
      "type": "object",
      "additionalProperties": false,
      "required": ["and"],
      "properties": { "and": { "$ref": "#/$defs/junction" } }
    },
    "or": {
      "type": "object",
      "additionalProperties": false,
      "required": ["or"],
      "properties": { "or": { "$ref": "#/$defs/junction" } }
    },
    "unary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operand"],
      "properties": { "operand": { "$ref": "#/$defs/operation" } }
    },
    "not": {
      "type": "object",
      "additionalProperties": false,
      "required": ["not"],
      "properties": { "not": { "$ref": "#/$defs/unary" } }
    },
    "group": {
      "description": "An explicit precedence-nesting node. It wraps a single inner operation so that a fluent or prefix surface that intends to group a sub-expression serializes to one unambiguous canonical form.",
      "type": "object",
      "additionalProperties": false,
      "required": ["group"],
      "properties": { "group": { "$ref": "#/$defs/unary" } }
    },

    "orderBy": {
      "description": "A result-shaping directive: order an inner query's rows by one or more keys.",
      "type": "object",
      "additionalProperties": false,
      "required": ["orderBy"],
      "properties": {
        "orderBy": {
          "type": "object",
          "additionalProperties": false,
          "required": ["operand", "keys"],
          "properties": {
            "operand": { "$ref": "#/$defs/operation" },
            "keys": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["attr"],
                "properties": {
                  "attr": { "$ref": "#/$defs/attributeRef" },
                  "direction": { "enum": ["asc", "desc"], "default": "asc" }
                }
              }
            }
          }
        }
      }
    },
    "limit": {
      "description": "A result-shaping directive: cap an inner query's row count.",
      "type": "object",
      "additionalProperties": false,
      "required": ["limit"],
      "properties": {
        "limit": {
          "type": "object",
          "additionalProperties": false,
          "required": ["operand", "count"],
          "properties": {
            "operand": { "$ref": "#/$defs/operation" },
            "count": { "type": "integer", "minimum": 1 }
          }
        }
      }
    },
    "distinct": {
      "description": "A result-shaping directive: deduplicate an inner query's rows.",
      "type": "object",
      "additionalProperties": false,
      "required": ["distinct"],
      "properties": { "distinct": { "$ref": "#/$defs/unary" } }
    },

    "navigationFilter": {
      "description": "Filter the queried entity by traversing a relationship. `rel` names the relationship; the optional `op` constrains the related entity. With no `op` it is a pure existence check.",
      "type": "object",
      "additionalProperties": false,
      "required": ["rel"],
      "properties": {
        "rel": { "$ref": "#/$defs/relationshipRef" },
        "op": { "$ref": "#/$defs/operation" }
      }
    },
    "navigate": {
      "description": "navigate(rel) -> predicate: filter via traversal to a related entity. Lowers to a correlated EXISTS semi-join, so a to-many navigation never multiplies parent rows.",
      "type": "object",
      "additionalProperties": false,
      "required": ["navigate"],
      "properties": { "navigate": { "$ref": "#/$defs/navigationFilter" } }
    },
    "exists": {
      "description": "exists(rel[, op]): the queried entity has at least one related row (optionally matching `op`). Lowers to a correlated EXISTS.",
      "type": "object",
      "additionalProperties": false,
      "required": ["exists"],
      "properties": { "exists": { "$ref": "#/$defs/navigationFilter" } }
    },
    "notExists": {
      "description": "notExists(rel[, op]): the queried entity has no related row (optionally matching `op`). Lowers to a correlated NOT EXISTS.",
      "type": "object",
      "additionalProperties": false,
      "required": ["notExists"],
      "properties": { "notExists": { "$ref": "#/$defs/navigationFilter" } }
    },
    "deepFetch": {
      "description": "An eager-fetch directive: resolve the inner query, then fetch each named navigation path with ONE additional statement per relationship level (N+1 elimination). The result is an object graph, not a flat row set.",
      "type": "object",
      "additionalProperties": false,
      "required": ["deepFetch"],
      "properties": {
        "deepFetch": {
          "type": "object",
          "additionalProperties": false,
          "required": ["operand", "paths"],
          "properties": {
            "operand": { "$ref": "#/$defs/operation" },
            "paths": {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/$defs/navigationPath" }
            }
          }
        }
      }
    },

    "aggregateFunction": {
      "description": "An aggregate function applied to an attribute (M2 sub-area). `as` is the result column name. `count` MAY omit `attr` to count whole rows in the group (count(*)); every other function requires `attr`.",
      "type": "object",
      "minProperties": 1,
      "maxProperties": 1,
      "oneOf": [
        { "$ref": "#/$defs/sum" },
        { "$ref": "#/$defs/avg" },
        { "$ref": "#/$defs/count" },
        { "$ref": "#/$defs/min" },
        { "$ref": "#/$defs/max" },
        { "$ref": "#/$defs/stdDevSample" },
        { "$ref": "#/$defs/stdDevPop" },
        { "$ref": "#/$defs/varianceSample" },
        { "$ref": "#/$defs/variancePop" }
      ]
    },
    "aggregateBody": {
      "description": "An aggregate over a named attribute, aliased by `as`.",
      "type": "object",
      "additionalProperties": false,
      "required": ["attr", "as"],
      "properties": {
        "attr": { "$ref": "#/$defs/attributeRef" },
        "as": { "$ref": "#/$defs/aggregateAlias" }
      }
    },
    "countBody": {
      "description": "count(attr) (non-NULL values) or count(*) when `attr` is omitted.",
      "type": "object",
      "additionalProperties": false,
      "required": ["as"],
      "properties": {
        "attr": { "$ref": "#/$defs/attributeRef" },
        "as": { "$ref": "#/$defs/aggregateAlias" }
      }
    },
    "sum": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sum"],
      "properties": { "sum": { "$ref": "#/$defs/aggregateBody" } }
    },
    "avg": {
      "type": "object",
      "additionalProperties": false,
      "required": ["avg"],
      "properties": { "avg": { "$ref": "#/$defs/aggregateBody" } }
    },
    "count": {
      "type": "object",
      "additionalProperties": false,
      "required": ["count"],
      "properties": { "count": { "$ref": "#/$defs/countBody" } }
    },
    "min": {
      "type": "object",
      "additionalProperties": false,
      "required": ["min"],
      "properties": { "min": { "$ref": "#/$defs/aggregateBody" } }
    },
    "max": {
      "type": "object",
      "additionalProperties": false,
      "required": ["max"],
      "properties": { "max": { "$ref": "#/$defs/aggregateBody" } }
    },
    "stdDevSample": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stdDevSample"],
      "properties": { "stdDevSample": { "$ref": "#/$defs/aggregateBody" } }
    },
    "stdDevPop": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stdDevPop"],
      "properties": { "stdDevPop": { "$ref": "#/$defs/aggregateBody" } }
    },
    "varianceSample": {
      "type": "object",
      "additionalProperties": false,
      "required": ["varianceSample"],
      "properties": { "varianceSample": { "$ref": "#/$defs/aggregateBody" } }
    },
    "variancePop": {
      "type": "object",
      "additionalProperties": false,
      "required": ["variancePop"],
      "properties": { "variancePop": { "$ref": "#/$defs/aggregateBody" } }
    },

    "havingComparison": {
      "description": "An aggregate comparison: an aggregate function compared against a literal. The leaf of a having expression.",
      "type": "object",
      "additionalProperties": false,
      "required": ["agg", "value"],
      "properties": {
        "agg": { "$ref": "#/$defs/aggregateFunction" },
        "value": { "$ref": "#/$defs/literal" }
      }
    },
    "havingExpression": {
      "description": "A boolean expression over aggregate comparisons (having leaves) composed with and/or. A having leaf is one of eq/notEq/gt/gte/lt/lte over an aggregate function.",
      "type": "object",
      "minProperties": 1,
      "maxProperties": 1,
      "oneOf": [
        { "$ref": "#/$defs/havingEq" },
        { "$ref": "#/$defs/havingNotEq" },
        { "$ref": "#/$defs/havingGt" },
        { "$ref": "#/$defs/havingGte" },
        { "$ref": "#/$defs/havingLt" },
        { "$ref": "#/$defs/havingLte" },
        { "$ref": "#/$defs/havingAnd" },
        { "$ref": "#/$defs/havingOr" }
      ]
    },
    "havingEq": {
      "type": "object",
      "additionalProperties": false,
      "required": ["eq"],
      "properties": { "eq": { "$ref": "#/$defs/havingComparison" } }
    },
    "havingNotEq": {
      "type": "object",
      "additionalProperties": false,
      "required": ["notEq"],
      "properties": { "notEq": { "$ref": "#/$defs/havingComparison" } }
    },
    "havingGt": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gt"],
      "properties": { "gt": { "$ref": "#/$defs/havingComparison" } }
    },
    "havingGte": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gte"],
      "properties": { "gte": { "$ref": "#/$defs/havingComparison" } }
    },
    "havingLt": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lt"],
      "properties": { "lt": { "$ref": "#/$defs/havingComparison" } }
    },
    "havingLte": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lte"],
      "properties": { "lte": { "$ref": "#/$defs/havingComparison" } }
    },
    "havingJunction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operands"],
      "properties": {
        "operands": {
          "type": "array",
          "minItems": 2,
          "items": { "$ref": "#/$defs/havingExpression" }
        }
      }
    },
    "havingAnd": {
      "type": "object",
      "additionalProperties": false,
      "required": ["and"],
      "properties": { "and": { "$ref": "#/$defs/havingJunction" } }
    },
    "havingOr": {
      "type": "object",
      "additionalProperties": false,
      "required": ["or"],
      "properties": { "or": { "$ref": "#/$defs/havingJunction" } }
    },

    "groupBy": {
      "description": "The aggregation node (M2 sub-area). Groups `operand`'s rows by `keys` (omit for a whole-table aggregate), projects one or more aggregate functions, and optionally filters groups with `having`. Lowers to a GROUP BY / HAVING SELECT via M3.",
      "type": "object",
      "additionalProperties": false,
      "required": ["groupBy"],
      "properties": {
        "groupBy": {
          "type": "object",
          "additionalProperties": false,
          "required": ["operand", "aggregates"],
          "properties": {
            "operand": { "$ref": "#/$defs/operation" },
            "keys": {
              "type": "array",
              "items": { "$ref": "#/$defs/attributeRef" }
            },
            "aggregates": {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/$defs/aggregateFunction" }
            },
            "having": { "$ref": "#/$defs/havingExpression" }
          }
        }
      }
    },

    "asOfAttributeRef": {
      "description": "A metamodel as-of-attribute reference of the form Class.asOfAttribute.",
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9]*\\.[a-z][A-Za-z0-9]*$"
    },
    "temporalDate": {
      "description": "A temporal pin value: an ISO-8601 UTC instant string, or the keyword `now` (as-of the current instant ⇒ the current milestone).",
      "type": "string",
      "minLength": 1
    },
    "asOf": {
      "description": "asOf(asOfAttr, date): pin a temporal dimension to a single instant. The queried entity's rows are restricted to the milestone whose [from, to) interval contains `date` (date = `now` ⇒ the current row, to = infinity). The temporal predicate is AUTO-INJECTED from the as-of model; the user never writes the from/to comparisons by hand. An omitted dimension defaults to `now` (M7 default-injection rule). A BITEMPORAL entity pins BOTH axes by nesting one asOf per axis (the inner asOf's `operand` is the next axis's pin); each axis injects its own interval predicate (Phase 8).",
      "type": "object",
      "additionalProperties": false,
      "required": ["asOf"],
      "properties": {
        "asOf": {
          "type": "object",
          "additionalProperties": false,
          "required": ["operand", "asOfAttr", "date"],
          "properties": {
            "operand": { "$ref": "#/$defs/operation" },
            "asOfAttr": { "$ref": "#/$defs/asOfAttributeRef" },
            "date": { "$ref": "#/$defs/temporalDate" }
          }
        }
      }
    },
    "asOfRange": {
      "description": "asOfRange(asOfAttr, from, to): scan a temporal dimension across a half-open instant range, returning every milestone that overlaps [from, to). Reads the interval columns as edge points (the milestone's own from/to satisfy the overlap), not a single containment pin.",
      "type": "object",
      "additionalProperties": false,
      "required": ["asOfRange"],
      "properties": {
        "asOfRange": {
          "type": "object",
          "additionalProperties": false,
          "required": ["operand", "asOfAttr", "from", "to"],
          "properties": {
            "operand": { "$ref": "#/$defs/operation" },
            "asOfAttr": { "$ref": "#/$defs/asOfAttributeRef" },
            "from": { "$ref": "#/$defs/temporalDate" },
            "to": { "$ref": "#/$defs/temporalDate" }
          }
        }
      }
    },
    "history": {
      "description": "history(asOfAttr): return the FULL set of milestone rows for a temporal dimension (Reladomo's equalsEdgePoint, renamed). No as-of predicate is injected on that axis, so every interval (current and superseded) is returned.",
      "type": "object",
      "additionalProperties": false,
      "required": ["history"],
      "properties": {
        "history": {
          "type": "object",
          "additionalProperties": false,
          "required": ["operand", "asOfAttr"],
          "properties": {
            "operand": { "$ref": "#/$defs/operation" },
            "asOfAttr": { "$ref": "#/$defs/asOfAttributeRef" }
          }
        }
      }
    },

    "nestedRef": {
      "description": "A reference into a valueObject's inner field: `Class.valueObject` followed by one or more dotted path segments into the embedded JSON (e.g. Customer.address.city, Customer.address.geo.lat). Lowers to a JSONB extraction on the value object's backing column (M3).",
      "type": "string",
