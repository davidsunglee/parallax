{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://parallax.dev/schemas/operation.schema.json",
  "title": "Parallax Operation Algebra (M2)",
  "description": "Canonical, format-agnostic serialization of an M2 operation node. Each node is a single-key tagged object. Grown one algebra phase at a time; this revision covers the full non-temporal single-entity algebra: identities, equality/range, null, string (with case-insensitive + escape rules), membership, boolean (incl. the first-class group node), and the orderBy / limit / distinct directives.",
  "$ref": "#/$defs/operation",
  "$defs": {
    "attributeRef": {
      "description": "A metamodel attribute reference of the form Class.attribute.",
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9]*\\.[a-z][A-Za-z0-9]*$"
    },
    "literal": {
      "description": "A scalar literal value usable as a bind.",
      "type": ["string", "number", "boolean", "null"]
    },
    "operation": {
      "type": "object",
      "minProperties": 1,
      "maxProperties": 1,
      "oneOf": [
        { "$ref": "#/$defs/all" },
        { "$ref": "#/$defs/none" },
        { "$ref": "#/$defs/eq" },
        { "$ref": "#/$defs/notEq" },
        { "$ref": "#/$defs/greaterThan" },
        { "$ref": "#/$defs/greaterThanEquals" },
        { "$ref": "#/$defs/lessThan" },
        { "$ref": "#/$defs/lessThanEquals" },
        { "$ref": "#/$defs/between" },
        { "$ref": "#/$defs/isNull" },
        { "$ref": "#/$defs/isNotNull" },
        { "$ref": "#/$defs/like" },
        { "$ref": "#/$defs/notLike" },
        { "$ref": "#/$defs/startsWith" },
        { "$ref": "#/$defs/endsWith" },
        { "$ref": "#/$defs/contains" },
        { "$ref": "#/$defs/in" },
        { "$ref": "#/$defs/notIn" },
        { "$ref": "#/$defs/and" },
        { "$ref": "#/$defs/or" },
        { "$ref": "#/$defs/not" },
        { "$ref": "#/$defs/group" },
        { "$ref": "#/$defs/orderBy" },
        { "$ref": "#/$defs/limit" },
        { "$ref": "#/$defs/distinct" }
      ]
    },

    "all": {
      "type": "object",
      "additionalProperties": false,
      "required": ["all"],
      "properties": {
        "all": { "type": "object", "additionalProperties": false }
      }
    },
    "none": {
      "type": "object",
      "additionalProperties": false,
      "required": ["none"],
      "properties": {
        "none": { "type": "object", "additionalProperties": false }
      }
    },

    "comparison": {
      "type": "object",
      "additionalProperties": false,
      "required": ["attr", "value"],
      "properties": {
        "attr": { "$ref": "#/$defs/attributeRef" },
        "value": { "$ref": "#/$defs/literal" }
      }
    },
    "eq": {
      "type": "object",
      "additionalProperties": false,
      "required": ["eq"],
      "properties": { "eq": { "$ref": "#/$defs/comparison" } }
    },
    "notEq": {
      "type": "object",
      "additionalProperties": false,
      "required": ["notEq"],
      "properties": { "notEq": { "$ref": "#/$defs/comparison" } }
    },
    "greaterThan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["greaterThan"],
      "properties": { "greaterThan": { "$ref": "#/$defs/comparison" } }
    },
    "greaterThanEquals": {
      "type": "object",
      "additionalProperties": false,
      "required": ["greaterThanEquals"],
      "properties": { "greaterThanEquals": { "$ref": "#/$defs/comparison" } }
    },
    "lessThan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lessThan"],
      "properties": { "lessThan": { "$ref": "#/$defs/comparison" } }
    },
    "lessThanEquals": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lessThanEquals"],
      "properties": { "lessThanEquals": { "$ref": "#/$defs/comparison" } }
    },

    "between": {
      "type": "object",
      "additionalProperties": false,
      "required": ["between"],
      "properties": {
        "between": {
          "type": "object",
          "additionalProperties": false,
          "required": ["attr", "lower", "upper"],
          "properties": {
            "attr": { "$ref": "#/$defs/attributeRef" },
            "lower": { "$ref": "#/$defs/literal" },
            "upper": { "$ref": "#/$defs/literal" }
          }
        }
      }
    },

    "nullCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": ["attr"],
      "properties": { "attr": { "$ref": "#/$defs/attributeRef" } }
    },
    "isNull": {
      "type": "object",
      "additionalProperties": false,
      "required": ["isNull"],
      "properties": { "isNull": { "$ref": "#/$defs/nullCheck" } }
    },
    "isNotNull": {
      "type": "object",
      "additionalProperties": false,
      "required": ["isNotNull"],
      "properties": { "isNotNull": { "$ref": "#/$defs/nullCheck" } }
    },

    "stringMatch": {
      "description": "A string predicate. `value` is a plain string; `like`/`notLike` interpret `%`/`_` as wildcards, the affix forms (startsWith/endsWith/contains) treat `value` as a literal and the implementation escapes wildcards. `caseInsensitive` defaults to false.",
      "type": "object",
      "additionalProperties": false,
      "required": ["attr", "value"],
      "properties": {
        "attr": { "$ref": "#/$defs/attributeRef" },
        "value": { "type": "string" },
        "caseInsensitive": { "type": "boolean", "default": false }
      }
    },
    "like": {
      "type": "object",
      "additionalProperties": false,
      "required": ["like"],
      "properties": { "like": { "$ref": "#/$defs/stringMatch" } }
    },
    "notLike": {
      "type": "object",
      "additionalProperties": false,
      "required": ["notLike"],
      "properties": { "notLike": { "$ref": "#/$defs/stringMatch" } }
    },
    "startsWith": {
      "type": "object",
      "additionalProperties": false,
      "required": ["startsWith"],
      "properties": { "startsWith": { "$ref": "#/$defs/stringMatch" } }
    },
    "endsWith": {
      "type": "object",
      "additionalProperties": false,
      "required": ["endsWith"],
      "properties": { "endsWith": { "$ref": "#/$defs/stringMatch" } }
    },
    "contains": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contains"],
      "properties": { "contains": { "$ref": "#/$defs/stringMatch" } }
    },

    "membership": {
      "type": "object",
      "additionalProperties": false,
      "required": ["attr", "values"],
      "properties": {
        "attr": { "$ref": "#/$defs/attributeRef" },
        "values": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/literal" }
        }
      }
    },
    "in": {
      "type": "object",
      "additionalProperties": false,
      "required": ["in"],
      "properties": { "in": { "$ref": "#/$defs/membership" } }
    },
    "notIn": {
      "type": "object",
      "additionalProperties": false,
      "required": ["notIn"],
      "properties": { "notIn": { "$ref": "#/$defs/membership" } }
    },

    "junction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operands"],
      "properties": {
        "operands": {
          "type": "array",
          "minItems": 2,
          "items": { "$ref": "#/$defs/operation" }
        }
      }
    },
    "and": {
      "type": "object",
      "additionalProperties": false,
      "required": ["and"],
      "properties": { "and": { "$ref": "#/$defs/junction" } }
    },
    "or": {
      "type": "object",
      "additionalProperties": false,
      "required": ["or"],
      "properties": { "or": { "$ref": "#/$defs/junction" } }
    },
    "unary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operand"],
      "properties": { "operand": { "$ref": "#/$defs/operation" } }
    },
    "not": {
      "type": "object",
      "additionalProperties": false,
      "required": ["not"],
      "properties": { "not": { "$ref": "#/$defs/unary" } }
    },
    "group": {
      "description": "An explicit precedence-nesting node. It wraps a single inner operation so that a fluent or prefix surface that intends to group a sub-expression serializes to one unambiguous canonical form.",
      "type": "object",
      "additionalProperties": false,
      "required": ["group"],
      "properties": { "group": { "$ref": "#/$defs/unary" } }
    },

    "orderBy": {
      "description": "A result-shaping directive: order an inner query's rows by one or more keys.",
      "type": "object",
      "additionalProperties": false,
      "required": ["orderBy"],
      "properties": {
        "orderBy": {
          "type": "object",
          "additionalProperties": false,
          "required": ["operand", "keys"],
          "properties": {
            "operand": { "$ref": "#/$defs/operation" },
            "keys": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["attr"],
                "properties": {
                  "attr": { "$ref": "#/$defs/attributeRef" },
                  "direction": { "enum": ["asc", "desc"], "default": "asc" }
                }
              }
            }
          }
        }
      }
    },
    "limit": {
      "description": "A result-shaping directive: cap an inner query's row count.",
      "type": "object",
      "additionalProperties": false,
      "required": ["limit"],
      "properties": {
        "limit": {
          "type": "object",
          "additionalProperties": false,
          "required": ["operand", "count"],
          "properties": {
            "operand": { "$ref": "#/$defs/operation" },
            "count": { "type": "integer", "minimum": 1 }
          }
        }
      }
    },
    "distinct": {
      "description": "A result-shaping directive: deduplicate an inner query's rows.",
      "type": "object",
      "additionalProperties": false,
      "required": ["distinct"],
      "properties": { "distinct": { "$ref": "#/$defs/unary" } }
    }
  }
}
