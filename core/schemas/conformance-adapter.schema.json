{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://parallax.dev/schemas/conformance-adapter.schema.json",
  "title": "Parallax Conformance Adapter Output",
  "description": "JSON output emitted by a language implementation conformance adapter. The adapter is the `m-conformance-adapter` seam used by external runners to ask a concrete language implementation what it supports, what SQL it emits for a compatibility case, and what observations it produces when it runs a case.",
  "oneOf": [
    { "$ref": "#/$defs/describeOk" },
    { "$ref": "#/$defs/compileOk" },
    { "$ref": "#/$defs/compileRunOnly" },
    { "$ref": "#/$defs/runOk" },
    { "$ref": "#/$defs/benchmarkOk" },
    { "$ref": "#/$defs/nonOk" }
  ],
  "$defs": {
    "schemaVersion": {
      "type": "string",
      "const": "1"
    },
    "command": {
      "type": "string",
      "enum": ["describe", "compile", "run", "benchmark"]
    },
    "adapter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["language", "name", "version"],
      "properties": {
        "language": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "dialect": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "casePath": {
      "type": "string",
      "pattern": "^(core/compatibility/cases/|cases/).+\\.ya?ml$"
    },
    "benchmarkPath": {
      "type": "string",
      "pattern": "^(core/compatibility/benchmarks/|benchmarks/).+\\.ya?ml$"
    },
    "caseShape": {
      "type": "string",
      "enum": ["read", "writeSequence", "scenario", "conflict", "coherence", "error", "concurrencySuccess", "boundary", "rejected"]
    },
    "moduleTag": {
      "type": "string",
      "pattern": "^m-[a-z0-9]+(-[a-z0-9]+)*$"
    },
    "caseShapeList": {
      "type": "array",
      "items": { "$ref": "#/$defs/caseShape" },
      "uniqueItems": true
    },
    "caseTag": {
      "description": "A compatibility case tag from a case's `tags` array.",
      "type": "string",
      "minLength": 1
    },
    "caseTagList": {
      "type": "array",
      "items": { "$ref": "#/$defs/caseTag" },
      "uniqueItems": true
    },
    "caseTagClaims": {
      "description": "Optional tag filters that narrow broad module/case-shape claims. `include` means a case must have at least one listed tag; `exclude` means a case with any listed tag is outside the claim.",
      "type": "object",
      "additionalProperties": false,
      "anyOf": [
        { "required": ["include"] },
        { "required": ["exclude"] }
      ],
      "properties": {
        "include": { "$ref": "#/$defs/caseTagList" },
        "exclude": { "$ref": "#/$defs/caseTagList" }
      }
    },
    "commandList": {
      "type": "array",
      "items": { "$ref": "#/$defs/command" },
      "uniqueItems": true
    },
    "diagnostic": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message"],
      "properties": {
        "code": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "casePointer": {
          "$ref": "#/$defs/jsonPointer"
        },
        "details": {}
      }
    },
    "diagnostics": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/diagnostic" }
    },
    "jsonPointer": {
      "type": "string",
      "pattern": "^($|/.*)$"
    },
    "bindValue": {
      "description": "A JSON-serializable bind value. Objects and arrays are allowed for structured-document values such as JSON, JSONB, or VARIANT.",
      "type": ["string", "number", "boolean", "null", "object", "array"]
    },
    "binds": {
      "type": "array",
      "items": { "$ref": "#/$defs/bindValue" }
    },
    "emission": {
      "type": "object",
      "additionalProperties": false,
      "required": ["casePointer", "sql", "binds"],
      "properties": {
        "casePointer": {
          "$ref": "#/$defs/jsonPointer"
        },
        "sql": {
          "type": "string",
          "minLength": 1
        },
        "binds": {
          "$ref": "#/$defs/binds"
        }
      }
    },
    "emissions": {
      "type": "array",
      "items": { "$ref": "#/$defs/emission" }
    },
    "row": {
      "type": "object",
      "additionalProperties": true
    },
    "rows": {
      "type": "array",
      "items": { "$ref": "#/$defs/row" }
    },
    "identityCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": ["left", "right", "same"],
      "properties": {
        "left": {
          "$ref": "#/$defs/jsonPointer"
        },
        "right": {
          "$ref": "#/$defs/jsonPointer"
        },
        "same": {
          "type": "boolean"
        },
        "identity": {}
      }
    },
    "stateCheck": {
      "description": "A lifecycle-state observation (m-conformance-adapter, COR-30): the object at case position `at` was observed in a given lifecycle state, and `pass` records whether that matched the case's `expectState`. `at` is a JSON Pointer into the case (a scenario step index). Mirrors `identityCheck`'s explicit-verdict shape so the runner grades an assertion the wire golden SQL cannot see.",
      "type": "object",
      "additionalProperties": false,
      "required": ["at", "expected", "observed", "pass"],
      "properties": {
        "at": {
          "$ref": "#/$defs/jsonPointer"
        },
        "expected": {
          "type": "string",
          "enum": ["in-memory", "persisted", "deleted", "detached", "detached-deleted"]
        },
        "observed": {
          "type": "string"
        },
        "pass": {
          "type": "boolean"
        }
      }
    },
    "errorObservation": {
      "description": "A raised-application-error observation (m-conformance-adapter, COR-30): the verb at case position `at` raised the neutral application-lifecycle error `errorClass`, from the closed vocabulary the case's `expectError` names (m-detach / m-identity-map). Distinct from the m-db-error taxonomy; `native` optionally carries the implementation's raw error payload as an unconstrained witness.",
      "type": "object",
      "additionalProperties": false,
      "required": ["at", "errorClass"],
      "properties": {
        "at": {
          "$ref": "#/$defs/jsonPointer"
        },
        "errorClass": {
          "type": "string",
          "enum": ["detached-relationship-load", "processing-pin-read-only"]
        },
        "native": {}
      }
    },
    "milestoneGraphObservation": {
      "description": "One edge-pinned graph in the ordered observation for a milestone-set snapshot read. The pin is the milestone's own from-instant per as-of axis, keyed by as-of attribute name; graph has the same root-class-keyed shape as a single graph observation.",
      "type": "object",
      "additionalProperties": false,
      "required": ["pin", "graph"],
      "properties": {
        "pin": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": { "type": "string", "minLength": 1 }
        },
        "graph": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "array",
            "items": { "type": "object" }
          }
        }
      }
    },
    "observations": {
      "type": "object",
      "additionalProperties": false,
      "required": ["roundTrips"],
      "properties": {
        "rows": {
          "$ref": "#/$defs/rows"
        },
        "graph": {
          "type": ["object", "null"],
          "additionalProperties": true
        },
        "graphs": {
          "description": "The ordered per-milestone snapshot graphs produced by a history or asOfRange read, compared entry-for-entry with the case's then.graphs oracle.",
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/milestoneGraphObservation" }
        },
        "tableState": {
          "type": ["object", "null"],
          "additionalProperties": {
            "type": "array",
            "items": { "$ref": "#/$defs/row" }
          }
        },
        "affectedRows": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "roundTrips": {
          "type": "integer",
          "minimum": 0
        },
        "identityChecks": {
          "type": "array",
          "items": { "$ref": "#/$defs/identityCheck" }
        },
        "stateChecks": {
          "description": "Lifecycle-state checks (m-detach five-state machine) an adapter reports for scenario steps declaring `expectState`. Optional and additive — an adapter that reports no lifecycle state omits it, and existing run outputs stay valid.",
          "type": "array",
          "items": { "$ref": "#/$defs/stateCheck" }
        },
        "errors": {
          "description": "Neutral application-lifecycle errors (m-detach / m-identity-map) an adapter reports for scenario steps declaring `expectError`. Optional and additive — an adapter that raises no such error omits it, and existing run outputs stay valid.",
          "type": "array",
          "items": { "$ref": "#/$defs/errorObservation" }
        }
      }
    },
    "wallTimeMs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["p50", "p95"],
      "properties": {
        "p50": {
          "type": "number",
          "minimum": 0
        },
        "p95": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "benchmarkWorkload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "iterations", "wallTimeMs", "roundTrips"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "iterations": {
          "type": "integer",
          "minimum": 1
        },
        "wallTimeMs": {
          "$ref": "#/$defs/wallTimeMs"
        },
        "roundTrips": {
          "type": "integer",
          "minimum": 0
        },
        "expectRoundTrips": {
          "type": "integer",
          "minimum": 0
        },
        "roundTripsOk": {
          "type": "boolean"
        }
      }
    },
    "benchmarkEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fixture", "model", "datasetRows", "workloads"],
      "properties": {
        "fixture": {
          "type": "string",
          "minLength": 1
        },
        "model": {
          "type": "string",
          "minLength": 1
        },
        "datasetRows": {
          "type": "integer",
          "minimum": 0
        },
        "workloads": {
          "type": "array",
          "items": { "$ref": "#/$defs/benchmarkWorkload" }
        }
      }
    },
    "benchmarkMemory": {
      "type": "object",
      "additionalProperties": false,
      "required": ["peakBytes", "steadyBytes"],
      "properties": {
        "peakBytes": {
          "type": "integer",
          "minimum": 0
        },
        "steadyBytes": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "benchmarkReport": {
      "type": "object",
      "additionalProperties": false,
      "required": ["generatedAt", "dialect", "benchmarks", "memory"],
      "properties": {
        "generatedAt": {
          "type": "string",
          "minLength": 1
        },
        "dialect": { "$ref": "#/$defs/dialect" },
        "benchmarks": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/benchmarkEntry" }
        },
        "memory": { "$ref": "#/$defs/benchmarkMemory" }
      }
    },
    "commonOk": {
      "type": "object",
      "required": ["schemaVersion", "command", "status", "adapter"],
      "properties": {
        "schemaVersion": { "$ref": "#/$defs/schemaVersion" },
        "command": { "$ref": "#/$defs/command" },
        "status": { "const": "ok" },
        "adapter": { "$ref": "#/$defs/adapter" }
      }
    },
    "describeOk": {
      "allOf": [
        { "$ref": "#/$defs/commonOk" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["schemaVersion", "command", "status", "adapter", "capabilities"],
          "properties": {
            "schemaVersion": { "$ref": "#/$defs/schemaVersion" },
            "command": { "const": "describe" },
            "status": { "const": "ok" },
            "adapter": { "$ref": "#/$defs/adapter" },
            "capabilities": {
              "type": "object",
              "additionalProperties": false,
              "required": ["modules", "dialects", "caseShapes", "commands", "provisioning"],
              "properties": {
                "modules": {
                  "type": "array",
                  "items": { "$ref": "#/$defs/moduleTag" },
                  "uniqueItems": true
                },
                "dialects": {
                  "type": "array",
                  "items": { "$ref": "#/$defs/dialect" },
                  "uniqueItems": true
                },
                "caseShapes": {
                  "$ref": "#/$defs/caseShapeList"
                },
                "caseTags": {
                  "$ref": "#/$defs/caseTagClaims"
                },
                "commands": {
                  "$ref": "#/$defs/commandList"
                },
                "provisioning": {
                  "type": "string",
                  "enum": ["external-url", "self-managed"]
                }
              }
            }
          }
        }
      ]
    },
    "compileOk": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "command",
        "status",
        "adapter",
        "case",
        "dialect",
        "caseShape",
        "emissions",
        "roundTrips"
      ],
      "properties": {
        "schemaVersion": { "$ref": "#/$defs/schemaVersion" },
        "command": { "const": "compile" },
        "status": { "const": "ok" },
        "adapter": { "$ref": "#/$defs/adapter" },
        "case": { "$ref": "#/$defs/casePath" },
        "dialect": { "$ref": "#/$defs/dialect" },
        "caseShape": { "$ref": "#/$defs/caseShape" },
        "emissions": { "$ref": "#/$defs/emissions" },
        "roundTrips": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "compileRunOnly": {
      "description": "The defined `compile` answer for a CLAIMED case the corpus declares RUN-ONLY (`compileEligibility`, m-case-format). Its emissions cannot be derived without executing SQL, so the adapter neither compiles it (that would require running a query) nor returns `unsupported` (invalid for a claimed case command). Instead it returns `status: run-only` with at least one `compile-run-only` diagnostic; only the `run` command grades the case. Exit code 11.",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "command",
        "status",
        "adapter",
        "case",
        "dialect",
        "caseShape",
        "diagnostics"
      ],
      "properties": {
        "schemaVersion": { "$ref": "#/$defs/schemaVersion" },
        "command": { "const": "compile" },
        "status": { "const": "run-only" },
        "adapter": { "$ref": "#/$defs/adapter" },
        "case": { "$ref": "#/$defs/casePath" },
        "dialect": { "$ref": "#/$defs/dialect" },
        "caseShape": { "$ref": "#/$defs/caseShape" },
        "diagnostics": {
          "allOf": [
            { "$ref": "#/$defs/diagnostics" },
            {
              "description": "At least one diagnostic MUST carry the reserved code `compile-run-only` naming the run-only reason.",
              "contains": {
                "type": "object",
                "required": ["code"],
                "properties": { "code": { "const": "compile-run-only" } }
              }
            }
          ]
        }
      }
    },
    "runOk": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "command",
        "status",
        "adapter",
        "case",
        "dialect",
        "caseShape",
        "emissions",
        "observations"
      ],
      "properties": {
        "schemaVersion": { "$ref": "#/$defs/schemaVersion" },
        "command": { "const": "run" },
        "status": { "const": "ok" },
        "adapter": { "$ref": "#/$defs/adapter" },
        "case": { "$ref": "#/$defs/casePath" },
        "dialect": { "$ref": "#/$defs/dialect" },
        "caseShape": { "$ref": "#/$defs/caseShape" },
        "emissions": { "$ref": "#/$defs/emissions" },
        "observations": { "$ref": "#/$defs/observations" }
      }
    },
    "benchmarkOk": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "command",
        "status",
        "adapter",
        "benchmark",
        "report"
      ],
      "properties": {
        "schemaVersion": { "$ref": "#/$defs/schemaVersion" },
        "command": { "const": "benchmark" },
        "status": { "const": "ok" },
        "adapter": { "$ref": "#/$defs/adapter" },
        "benchmark": { "$ref": "#/$defs/benchmarkPath" },
        "report": { "$ref": "#/$defs/benchmarkReport" }
      }
    },
    "nonOk": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "command", "status", "adapter", "diagnostics"],
      "properties": {
        "schemaVersion": { "$ref": "#/$defs/schemaVersion" },
        "command": { "$ref": "#/$defs/command" },
        "status": {
          "type": "string",
          "enum": ["unsupported", "error"]
        },
        "adapter": { "$ref": "#/$defs/adapter" },
        "diagnostics": { "$ref": "#/$defs/diagnostics" }
      }
    }
  }
}
