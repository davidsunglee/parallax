{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://parallax.dev/schemas/conformance-adapter.schema.json",
  "title": "Parallax Conformance Adapter Output",
  "description": "JSON output emitted by a language implementation conformance adapter. The adapter is the M12-adjacent seam used by external runners to ask a concrete language implementation what it supports, what SQL it emits for a compatibility case, and what observations it produces when it runs a case.",
  "oneOf": [
    { "$ref": "#/$defs/describeOk" },
    { "$ref": "#/$defs/compileOk" },
    { "$ref": "#/$defs/runOk" },
    { "$ref": "#/$defs/benchmarkOk" },
    { "$ref": "#/$defs/nonOk" }
  ],
  "$defs": {
    "schemaVersion": {
      "type": "string",
      "const": "1"
    },
    "command": {
      "type": "string",
      "enum": ["describe", "compile", "run", "benchmark"]
    },
    "adapter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["language", "name", "version"],
      "properties": {
        "language": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "dialect": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "casePath": {
      "type": "string",
      "pattern": "^(core/compatibility/cases/|cases/).+\\.ya?ml$"
    },
    "benchmarkPath": {
      "type": "string",
      "pattern": "^(core/compatibility/benchmarks/|benchmarks/).+\\.ya?ml$"
    },
    "caseShape": {
      "type": "string",
      "enum": ["read", "writeSequence", "scenario", "conflict", "coherence"]
    },
    "moduleTag": {
      "type": "string",
      "pattern": "^m[0-9]+$|^coherence$"
    },
    "caseShapeList": {
      "type": "array",
      "items": { "$ref": "#/$defs/caseShape" },
      "uniqueItems": true
    },
    "caseTag": {
      "description": "A compatibility case tag from a case's `tags` array.",
      "type": "string",
      "minLength": 1
    },
    "caseTagList": {
      "type": "array",
      "items": { "$ref": "#/$defs/caseTag" },
      "uniqueItems": true
    },
    "caseTagClaims": {
      "description": "Optional tag filters that narrow broad module/case-shape claims. `include` means a case must have at least one listed tag; `exclude` means a case with any listed tag is outside the claim.",
      "type": "object",
      "additionalProperties": false,
      "anyOf": [
        { "required": ["include"] },
        { "required": ["exclude"] }
      ],
      "properties": {
        "include": { "$ref": "#/$defs/caseTagList" },
        "exclude": { "$ref": "#/$defs/caseTagList" }
      }
    },
    "commandList": {
      "type": "array",
      "items": { "$ref": "#/$defs/command" },
      "uniqueItems": true
    },
    "diagnostic": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message"],
      "properties": {
        "code": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "casePointer": {
          "$ref": "#/$defs/jsonPointer"
        },
        "details": {}
      }
    },
    "diagnostics": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/diagnostic" }
    },
    "jsonPointer": {
      "type": "string",
      "pattern": "^($|/.*)$"
    },
    "bindValue": {
      "description": "A JSON-serializable bind value. Objects and arrays are allowed for structured-document values such as JSON, JSONB, or VARIANT.",
      "type": ["string", "number", "boolean", "null", "object", "array"]
    },
    "binds": {
      "type": "array",
      "items": { "$ref": "#/$defs/bindValue" }
    },
    "emission": {
      "type": "object",
      "additionalProperties": false,
      "required": ["casePointer", "sql", "binds"],
      "properties": {
        "casePointer": {
          "$ref": "#/$defs/jsonPointer"
        },
        "sql": {
          "type": "string",
          "minLength": 1
        },
        "binds": {
          "$ref": "#/$defs/binds"
        }
      }
    },
    "emissions": {
      "type": "array",
      "items": { "$ref": "#/$defs/emission" }
    },
    "row": {
      "type": "object",
      "additionalProperties": true
    },
    "rows": {
      "type": "array",
      "items": { "$ref": "#/$defs/row" }
    },
    "identityCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": ["left", "right", "same"],
      "properties": {
        "left": {
          "$ref": "#/$defs/jsonPointer"
        },
        "right": {
          "$ref": "#/$defs/jsonPointer"
        },
        "same": {
          "type": "boolean"
        },
        "identity": {}
      }
    },
    "observations": {
      "type": "object",
      "additionalProperties": false,
      "required": ["roundTrips"],
      "properties": {
        "rows": {
          "$ref": "#/$defs/rows"
        },
        "graph": {
          "type": ["object", "null"],
          "additionalProperties": true
        },
        "tableState": {
          "type": ["object", "null"],
          "additionalProperties": {
            "type": "array",
            "items": { "$ref": "#/$defs/row" }
          }
        },
        "affectedRows": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "roundTrips": {
          "type": "integer",
          "minimum": 0
        },
        "identityChecks": {
          "type": "array",
          "items": { "$ref": "#/$defs/identityCheck" }
        }
      }
    },
    "wallTimeMs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["p50", "p95"],
      "properties": {
        "p50": {
          "type": "number",
          "minimum": 0
        },
        "p95": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "benchmarkWorkload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "iterations", "wallTimeMs", "roundTrips"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "iterations": {
          "type": "integer",
          "minimum": 1
        },
        "wallTimeMs": {
          "$ref": "#/$defs/wallTimeMs"
        },
        "roundTrips": {
          "type": "integer",
          "minimum": 0
        },
        "expectRoundTrips": {
          "type": "integer",
          "minimum": 0
        },
        "roundTripsOk": {
          "type": "boolean"
        }
      }
    },
    "benchmarkEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fixture", "model", "datasetRows", "workloads"],
      "properties": {
        "fixture": {
          "type": "string",
          "minLength": 1
        },
        "model": {
          "type": "string",
          "minLength": 1
        },
        "datasetRows": {
          "type": "integer",
          "minimum": 0
        },
        "workloads": {
          "type": "array",
          "items": { "$ref": "#/$defs/benchmarkWorkload" }
        }
      }
    },
    "benchmarkMemory": {
      "type": "object",
      "additionalProperties": false,
      "required": ["peakBytes", "steadyBytes"],
      "properties": {
        "peakBytes": {
          "type": "integer",
          "minimum": 0
        },
        "steadyBytes": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "benchmarkReport": {
      "type": "object",
      "additionalProperties": false,
      "required": ["generatedAt", "dialect", "benchmarks", "memory"],
      "properties": {
        "generatedAt": {
          "type": "string",
          "minLength": 1
        },
        "dialect": { "$ref": "#/$defs/dialect" },
        "benchmarks": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/benchmarkEntry" }
        },
        "memory": { "$ref": "#/$defs/benchmarkMemory" }
      }
    },
    "commonOk": {
      "type": "object",
      "required": ["schemaVersion", "command", "status", "adapter"],
      "properties": {
        "schemaVersion": { "$ref": "#/$defs/schemaVersion" },
        "command": { "$ref": "#/$defs/command" },
        "status": { "const": "ok" },
        "adapter": { "$ref": "#/$defs/adapter" }
      }
    },
    "describeOk": {
      "allOf": [
        { "$ref": "#/$defs/commonOk" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["schemaVersion", "command", "status", "adapter", "capabilities"],
          "properties": {
            "schemaVersion": { "$ref": "#/$defs/schemaVersion" },
            "command": { "const": "describe" },
            "status": { "const": "ok" },
            "adapter": { "$ref": "#/$defs/adapter" },
            "capabilities": {
              "type": "object",
              "additionalProperties": false,
              "required": ["modules", "dialects", "caseShapes", "commands", "provisioning"],
              "properties": {
                "modules": {
                  "type": "array",
                  "items": { "$ref": "#/$defs/moduleTag" },
                  "uniqueItems": true
                },
                "dialects": {
                  "type": "array",
                  "items": { "$ref": "#/$defs/dialect" },
                  "uniqueItems": true
                },
                "caseShapes": {
                  "$ref": "#/$defs/caseShapeList"
                },
                "caseTags": {
                  "$ref": "#/$defs/caseTagClaims"
                },
                "commands": {
                  "$ref": "#/$defs/commandList"
                },
                "provisioning": {
                  "type": "string",
                  "enum": ["external-url", "self-managed"]
                }
              }
            }
          }
        }
      ]
    },
    "compileOk": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "command",
        "status",
        "adapter",
        "case",
        "dialect",
        "caseShape",
        "emissions",
        "roundTrips"
      ],
      "properties": {
        "schemaVersion": { "$ref": "#/$defs/schemaVersion" },
        "command": { "const": "compile" },
        "status": { "const": "ok" },
        "adapter": { "$ref": "#/$defs/adapter" },
        "case": { "$ref": "#/$defs/casePath" },
        "dialect": { "$ref": "#/$defs/dialect" },
        "caseShape": { "$ref": "#/$defs/caseShape" },
        "emissions": { "$ref": "#/$defs/emissions" },
        "roundTrips": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "runOk": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "command",
        "status",
        "adapter",
        "case",
        "dialect",
        "caseShape",
        "emissions",
        "observations"
      ],
      "properties": {
        "schemaVersion": { "$ref": "#/$defs/schemaVersion" },
        "command": { "const": "run" },
        "status": { "const": "ok" },
        "adapter": { "$ref": "#/$defs/adapter" },
        "case": { "$ref": "#/$defs/casePath" },
        "dialect": { "$ref": "#/$defs/dialect" },
        "caseShape": { "$ref": "#/$defs/caseShape" },
        "emissions": { "$ref": "#/$defs/emissions" },
        "observations": { "$ref": "#/$defs/observations" }
      }
    },
    "benchmarkOk": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "command",
        "status",
        "adapter",
        "benchmark",
        "report"
      ],
      "properties": {
        "schemaVersion": { "$ref": "#/$defs/schemaVersion" },
        "command": { "const": "benchmark" },
        "status": { "const": "ok" },
        "adapter": { "$ref": "#/$defs/adapter" },
        "benchmark": { "$ref": "#/$defs/benchmarkPath" },
        "report": { "$ref": "#/$defs/benchmarkReport" }
      }
    },
    "nonOk": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "command", "status", "adapter", "diagnostics"],
      "properties": {
        "schemaVersion": { "$ref": "#/$defs/schemaVersion" },
        "command": { "$ref": "#/$defs/command" },
        "status": {
          "type": "string",
          "enum": ["unsupported", "error"]
        },
        "adapter": { "$ref": "#/$defs/adapter" },
        "diagnostics": { "$ref": "#/$defs/diagnostics" }
      }
    }
  }
}
